{
  "manifest_version": 3,
  "name": "Portify - Your Internet, Perfected",
  "short_name": "Portify",
  "description": "Το πιο όμορφο και έξυπνο New Tab με bookmarks, smart προσθήκη και ελληνικά sites",
  "version": "2.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "offline_enabled": true
}

{
  "manifest_version": 3,
  "name": "Portify – Your Internet, One Place",
  "version": "3.5",
  "description": "Smart bookmark dashboard with cross-device sync, AI search, country tabs, drag & drop. Free, no sign-up.",
  "permissions": [
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Portify"
  }
}
